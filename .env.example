# Configurações de produção - PROD OLD ECOM
PROD_HOST=your-production-host
PROD_USER=your-production-user
PROD_PASS=your-production-password
PROD_DB=your-production-database

# Configurações de produção - CROSS PROD (Shopify)
CROSS_HOST=your-cross-prod-host
CROSS_USER=your-cross-prod-user
CROSS_PASS=your-cross-prod-password
CROSS_DB=your-cross-prod-database

# Portas locais (cada banco em sua porta)
OLD_ECOM_PORT=3306
CROSS_PROD_PORT=3307

# Configurações locais
LOCAL_HOST=127.0.0.1
LOCAL_USER=your-local-user
LOCAL_PASS=your-local-password

# Configurações do Docker
DOCKER_MYSQL_IMAGE=mysql:X.X
MYSQL_ROOT_PASSWORD=root-password
MYSQL_SQL_MODE=STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION
